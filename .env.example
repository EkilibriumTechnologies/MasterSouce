# Optional explicit ffmpeg path.
# Local Windows example:
# FFMPEG_BIN=C:\path\to\ffmpeg.exe
# Netlify/Linux example (only if you want to override packaged binary fallback):
# FFMPEG_BIN=/usr/bin/ffmpeg
FFMPEG_BIN=

# Optional explicit ffprobe path for WAV export validation / inspect script.
# Falls back to ffprobe on PATH, then ffmpeg -i parsing when unavailable.
# FFPROBE_BIN=C:\path\to\ffprobe.exe
FFPROBE_BIN=

# Paid 24-bit WAV delivery toggle (default: enabled when unset).
# Set to false to roll back Creator-plan exports to 16-bit PCM without changing DSP.
ENABLE_24_BIT_WAV_EXPORT=true

# Homepage Before & After audio demo (default: false / hidden).
# Temporarily gated until updated samples are generated using the current
# MasterSauce restoration and mastering pipeline. Set to true to re-enable.
HOMEPAGE_BEFORE_AFTER_ENABLED=false

# AI Audio Restoration (server-only; default disabled + owner-only).
# Never expose these as NEXT_PUBLIC_*. Authorization is resolved on the server.
AI_AUDIO_RESTORATION_ENABLED=false
AI_AUDIO_RESTORATION_OWNER_ONLY=true

# Internal diagnostics endpoint token (required to enable /api/internal/ffmpeg-runtime and /api/internal/job-export-verify).
INTERNAL_DIAGNOSTICS_TOKEN=

# Optional. Owner-testing token for strict bypass on GET /api/download.
# Bypass is granted only when BOTH request headers are present:
# - x-master-admin-bypass: 1
# - x-master-owner-token: <token matching this value>
MASTER_OWNER_TOKEN=

# Optional future data persistence DSN placeholder.
DATABASE_URL=

# Supabase (server-only: use the service role key in Route Handlers, never in client code)
# SUPABASE_SERVICE_ROLE_KEY must be the "service_role" secret from Supabase → Settings → API (not "anon").
# Prefer SUPABASE_URL in production (Railway); server also falls back to NEXT_PUBLIC_SUPABASE_URL at runtime.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional; same project URL as SUPABASE_URL when you only expose the public pair to the client:
# NEXT_PUBLIC_SUPABASE_URL=

# App URL for Stripe success/cancel redirects (e.g. https://mastersauce.app)
NEXT_PUBLIC_APP_URL=

# Canonical public site URL for SEO (Open Graph, sitemap, canonicals). Falls back to NEXT_PUBLIC_APP_URL if unset.
NEXT_PUBLIC_SITE_URL=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable loading gtag.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console HTML tag verification content value only (from the meta tag Google provides). Leave empty until verified.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Hit Analyzer free launch window end (ISO-8601 UTC). Defaults to one month after initial launch if unset.
# HIT_ANALYZER_FREE_LAUNCH_END_DATE=2026-07-30T23:59:59.999Z

# Optional. Comma-separated billing emails that always pass Adaptive entitlement checks
# and are exempt from export-access rate limits (e.g. support / comp accounts).
ADAPTIVE_BILLING_ALLOWLIST=

# Optional. Server-only owner/comp WAV export quality (does not change Stripe billing).
# Format: email:planId pairs (planId = creator_monthly | pro_studio_monthly).
# Example: consulting@example.com:pro_studio_monthly
MASTER_WAV_EXPORT_ALLOWLIST=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREATOR_MONTHLY=
STRIPE_PRICE_PRO_STUDIO_MONTHLY=
STRIPE_PRICE_CREDIT_PACK=
